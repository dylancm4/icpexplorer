{
  "name": "icpexplorer",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,json,css}": "biome check --write --no-errors-on-unmatched"
  }
}
